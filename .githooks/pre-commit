#!/usr/bin/env bash
# ============================================================
# .githooks/pre-commit
# Sadece stage'deki (git add) dosyalari kontrol eder.
#   - .js / .jsx / .ts / .tsx  -> ESLint + Prettier
#   - .java                    -> google-java-format (mevcut degil
#                                  ise checkstyle-light ile yedek)
# Hata varsa commit'i engeller (exit 1).
# ============================================================

set -euo pipefail

# Renk kodlari
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

REPO_ROOT="$(git rev-parse --show-toplevel)"
FRONTEND_DIR="$REPO_ROOT/frontend"
BACKEND_DIR="$REPO_ROOT/backend"

echo ""
echo -e "${BLUE}============================================${NC}"
echo -e "${BLUE}  Pre-Commit Kalite Kontrolu Basliyor...  ${NC}"
echo -e "${BLUE}============================================${NC}"
echo ""

# -------------------------------------------------------
# Stage'deki dosyalari al
# -------------------------------------------------------
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    echo -e "${YELLOW}Stage'de degisiklik yok, atlaniyor.${NC}"
    exit 0
fi

# -------------------------------------------------------
# Staged frontend dosyalari (js/jsx/ts/tsx)
# -------------------------------------------------------
FRONTEND_FILES=$(echo "$STAGED_FILES" | grep -E '^frontend/.*\.(js|jsx|ts|tsx)$' || true)

if [ -n "$FRONTEND_FILES" ]; then
    echo -e "${BLUE}[Frontend] Kontrol edilecek dosyalar:${NC}"
    echo "$FRONTEND_FILES" | sed 's/^/  /'
    echo ""

    # ESLint
    if [ -f "$FRONTEND_DIR/package.json" ] && \
       ([ -f "$FRONTEND_DIR/.eslintrc.js" ] || \
        [ -f "$FRONTEND_DIR/.eslintrc.cjs" ] || \
        [ -f "$FRONTEND_DIR/eslint.config.js" ]); then

        echo -e "${BLUE}[ESLint] Calistiriliyor...${NC}"
        cd "$FRONTEND_DIR"

        # Sadece stage'deki frontend dosyalarini pass et (repo-root'a gore)
        RELATIVE_FILES=$(echo "$FRONTEND_FILES" | sed 's|^frontend/||')

        if npm run lint -- --max-warnings=0 $RELATIVE_FILES 2>&1; then
            echo -e "${GREEN}[ESLint] BASARILI${NC}"
        else
            echo ""
            echo -e "${RED}[ESLint] HATA: Yukaridaki sorunlari duzeltip tekrar commit edin.${NC}"
            echo -e "${RED}NOT: Kuralları atlamak icin --no-verify KULLANMAYIN.${NC}"
            exit 1
        fi
        cd "$REPO_ROOT"
    else
        echo -e "${YELLOW}[ESLint] Konfigurason bulunamadi, atlaniyor.${NC}"
    fi

    # Prettier format kontrolu
    if [ -f "$FRONTEND_DIR/package.json" ] && \
       ([ -f "$FRONTEND_DIR/.prettierrc" ] || \
        [ -f "$FRONTEND_DIR/.prettierrc.js" ] || \
        [ -f "$FRONTEND_DIR/prettier.config.js" ]); then

        echo -e "${BLUE}[Prettier] Format kontrolu yapiliyor...${NC}"
        cd "$FRONTEND_DIR"
        RELATIVE_FILES=$(echo "$FRONTEND_FILES" | sed 's|^frontend/||')

        if npx prettier --check $RELATIVE_FILES 2>&1; then
            echo -e "${GREEN}[Prettier] BASARILI${NC}"
        else
            echo ""
            echo -e "${YELLOW}[Prettier] Format hatasi! Otomatik duzeltiliyor...${NC}"
            npx prettier --write $RELATIVE_FILES
            # Duzeltilen dosyalari tekrar stage'e ekle
            echo "$FRONTEND_FILES" | xargs git add
            echo -e "${GREEN}[Prettier] Dosyalar otomatik formatlanip stage'e eklendi.${NC}"
        fi
        cd "$REPO_ROOT"
    else
        echo -e "${YELLOW}[Prettier] Konfigurason bulunamadi, atlaniyor.${NC}"
    fi

    echo ""
fi

# -------------------------------------------------------
# Staged backend dosyalari (.java)
# -------------------------------------------------------
JAVA_FILES=$(echo "$STAGED_FILES" | grep -E '^backend/.*\.java$' || true)

if [ -n "$JAVA_FILES" ]; then
    echo -e "${BLUE}[Backend] Kontrol edilecek Java dosyalari:${NC}"
    echo "$JAVA_FILES" | sed 's/^/  /'
    echo ""

    if [ ! -f "$BACKEND_DIR/pom.xml" ]; then
        echo -e "${YELLOW}[Backend] pom.xml bulunamadi, atlaniyor.${NC}"
    else
        # google-java-format varsa kullan
        GJF_JAR="$HOME/.m2/repository/com/google/googlejavaformat/google-java-format/1.19.2/google-java-format-1.19.2-all-deps.jar"

        if [ -f "$GJF_JAR" ]; then
            echo -e "${BLUE}[google-java-format] Format kontrolu yapiliyor...${NC}"
            ABS_JAVA_FILES=$(echo "$JAVA_FILES" | sed "s|^|$REPO_ROOT/|")
            DIFF_OUTPUT=$(java -jar "$GJF_JAR" --dry-run $ABS_JAVA_FILES 2>&1 || true)

            if [ -n "$DIFF_OUTPUT" ]; then
                echo -e "${YELLOW}[google-java-format] Format hatasi tespit edildi. Duzeltiliyor...${NC}"
                java -jar "$GJF_JAR" --replace $ABS_JAVA_FILES
                echo "$JAVA_FILES" | xargs git add
                echo -e "${GREEN}[google-java-format] Java dosyalari formatlanip stage'e eklendi.${NC}"
            else
                echo -e "${GREEN}[google-java-format] BASARILI${NC}"
            fi
        else
            # Yedek: Maven compile ile hizli syntax kontrolu
            echo -e "${BLUE}[Maven] Hizli syntax kontrolu yapiliyor (compile -q)...${NC}"
            cd "$BACKEND_DIR"

            if mvn compile -q --no-transfer-progress 2>&1; then
                echo -e "${GREEN}[Maven Compile] BASARILI - Syntax hatalari yok.${NC}"
            else
                echo ""
                echo -e "${RED}[Maven Compile] HATA: Java syntax hatasi mevcut.${NC}"
                echo -e "${RED}Derlenemeyen dosyalar giderilmeden commit atilamaz.${NC}"
                exit 1
            fi
            cd "$REPO_ROOT"
        fi
    fi

    echo ""
fi

# -------------------------------------------------------
# Sonuc
# -------------------------------------------------------
echo -e "${GREEN}============================================${NC}"
echo -e "${GREEN}  Tum kontroller gecti. Commit devam ediyor.${NC}"
echo -e "${GREEN}============================================${NC}"
echo ""
exit 0
