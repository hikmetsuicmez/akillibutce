#!/usr/bin/env bash
# ============================================================
# .githooks/pre-push
# Push gerceklesmeden once tam guvenlik kontrolu yapar:
#   1. Backend: mvn clean test (tum unit testleri)
#   2. Frontend: npm run build (derleme dogrulamasi)
# Herhangi biri basarisiz olursa push IPTAL edilir.
#
# !! --no-verify ile bu hook ATLANAMAZ !!
# ============================================================

set -euo pipefail

# Renk kodlari
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

REPO_ROOT="$(git rev-parse --show-toplevel)"
FRONTEND_DIR="$REPO_ROOT/frontend"
BACKEND_DIR="$REPO_ROOT/backend"

BASARISIZ=0

echo ""
echo -e "${CYAN}================================================${NC}"
echo -e "${CYAN}   Pre-Push Guvenlik Kapisi Aktif             ${NC}"
echo -e "${CYAN}================================================${NC}"
echo ""

# Push edilen branch bilgisini al
while read -r local_ref local_sha remote_ref remote_sha; do
    BRANCH_NAME=$(echo "$local_ref" | sed 's|refs/heads/||')
    echo -e "${BLUE}Branch: ${BRANCH_NAME}${NC}"
    echo ""
done

# -------------------------------------------------------
# 1) BACKEND: mvn clean test
# -------------------------------------------------------
echo -e "${BLUE}[1/2] Backend Unit Testleri Calistiriliyor...${NC}"
echo -e "      Komut: mvn clean test -q"
echo ""

if [ ! -f "$BACKEND_DIR/pom.xml" ]; then
    echo -e "${YELLOW}[Backend] pom.xml bulunamadi, atlaniyor.${NC}"
else
    cd "$BACKEND_DIR"
    START_TIME=$(date +%s)

    if mvn clean test --no-transfer-progress 2>&1; then
        END_TIME=$(date +%s)
        ELAPSED=$((END_TIME - START_TIME))
        echo ""
        echo -e "${GREEN}[Backend] Tum testler GECTI (${ELAPSED}s)${NC}"
    else
        END_TIME=$(date +%s)
        ELAPSED=$((END_TIME - START_TIME))
        echo ""
        echo -e "${RED}======================================${NC}"
        echo -e "${RED}[Backend] TEST BASARISIZ (${ELAPSED}s)${NC}"
        echo -e "${RED}Hatalari duzeltip tekrar push edin.  ${NC}"
        echo -e "${RED}======================================${NC}"
        BASARISIZ=1
    fi
    cd "$REPO_ROOT"
fi

echo ""

# -------------------------------------------------------
# 2) FRONTEND: npm run build
# -------------------------------------------------------
echo -e "${BLUE}[2/2] Frontend Build Dogrulamasi Yapiliyor...${NC}"
echo -e "      Komut: npm run build"
echo ""

if [ ! -f "$FRONTEND_DIR/package.json" ]; then
    echo -e "${YELLOW}[Frontend] package.json bulunamadi, atlaniyor.${NC}"
else
    cd "$FRONTEND_DIR"

    # node_modules yoksa yukle
    if [ ! -d "node_modules" ]; then
        echo -e "${YELLOW}[Frontend] node_modules bulunamadi. npm install calistiriliyor...${NC}"
        npm install --silent
    fi

    START_TIME=$(date +%s)

    if npm run build 2>&1; then
        END_TIME=$(date +%s)
        ELAPSED=$((END_TIME - START_TIME))
        echo ""
        echo -e "${GREEN}[Frontend] Build BASARILI (${ELAPSED}s)${NC}"
    else
        END_TIME=$(date +%s)
        ELAPSED=$((END_TIME - START_TIME))
        echo ""
        echo -e "${RED}======================================${NC}"
        echo -e "${RED}[Frontend] BUILD BASARISIZ (${ELAPSED}s)${NC}"
        echo -e "${RED}Derleme hatalarini duzeltip tekrar push edin.${NC}"
        echo -e "${RED}======================================${NC}"
        BASARISIZ=1
    fi
    cd "$REPO_ROOT"
fi

echo ""

# -------------------------------------------------------
# Sonuc
# -------------------------------------------------------
if [ "$BASARISIZ" -eq 1 ]; then
    echo -e "${RED}================================================${NC}"
    echo -e "${RED}  PUSH IPTAL EDILDI                          ${NC}"
    echo -e "${RED}  Hatalari gidermeden push atilamaz.         ${NC}"
    echo -e "${RED}  NOT: --no-verify kullanmak yasaktir!       ${NC}"
    echo -e "${RED}================================================${NC}"
    echo ""
    exit 1
fi

echo -e "${GREEN}================================================${NC}"
echo -e "${GREEN}  Tum kontroller gecti. Push devam ediyor.   ${NC}"
echo -e "${GREEN}================================================${NC}"
echo ""
exit 0
